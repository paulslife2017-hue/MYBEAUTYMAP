{
  "version": 2,
  "installCommand": "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 npm install --omit=dev",
  "buildCommand": "echo 'using pre-built api files'",
  "rewrites": [
    { "source": "/api/admin/cloudinary-sign", "destination": "/api/cloudinary-sign" },
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
