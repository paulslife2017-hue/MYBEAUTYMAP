{
  "version": 2,
  "framework": null,
  "buildCommand": "npx vite build --config vite.config.node.ts",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/static/(.*)", "destination": "/static/$1" },
    { "source": "/favicon.svg", "destination": "/favicon.svg" },
    { "source": "/og-image.jpg", "destination": "/og-image.jpg" },
    { "source": "/(.*)", "destination": "/index.js" }
  ]
}
