{
  "version": 2,
  "builds": [
    {
      "src": "dist/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/dist/static/$1"
    },
    {
      "src": "/favicon.svg",
      "dest": "/dist/favicon.svg"
    },
    {
      "src": "/og-image.jpg",
      "dest": "/dist/og-image.jpg"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/index.js"
    }
  ]
}
